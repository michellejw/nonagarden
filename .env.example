# Supabase content backend (slice 2). Copy to .env.local and fill in real values.
# Find these in the Supabase dashboard: Project Settings → API.

# Public — safe to ship to the browser. RLS gates what the publishable key can read.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_...

# SECRET — server/seed only. Bypasses RLS. Never expose to the browser,
# never prefix with NEXT_PUBLIC_, never commit a real value.
SUPABASE_SECRET_KEY=                    # sb_secret_...
